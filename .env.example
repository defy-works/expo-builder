# Project name (used for VM directory mount, temp file prefixes, intro label)
PROJECT_NAME=my-app

# Path to the project root, relative to this directory
# Use ".." when used as a submodule, or "." if this IS the project
PROJECT_ROOT=..

# Relative path to the Expo/React Native mobile directory (from PROJECT_ROOT)
# Use "." if the project root IS the Expo project
PROJECT_MOBILE_DIR=mobile

# Remote Builder (Mac via SSH — builds run in Tart VM)
REMOTE_BUILDER_USER=your_ssh_username
REMOTE_BUILDER_HOST=your_ssh_host
REMOTE_BUILDER_PATH=~/eas/my-app

# Expo Token (for EAS CLI auth in Tart VM builds)
# Create at: expo.dev → Account Settings → Access Tokens
EXPO_TOKEN=your_expo_token

# Tart VM Xcode version (optional — used by setup-tart.ts, default: 26.2)
# Should match the EAS cloud image's Xcode version
# TART_XCODE_VERSION=26.2

# Tart VM base image (optional — default: ghcr.io/cirruslabs/macos-sequoia-xcode)
# TART_BASE_IMAGE=ghcr.io/cirruslabs/macos-sequoia-xcode

# Java version installed in VM (optional — default: 17)
# JAVA_VERSION=17

# Android SDK versions (optional — used by setup-tart.ts)
# ANDROID_PLATFORM=android-36
# ANDROID_BUILD_TOOLS=36.0.0
# ANDROID_NDK=27.1.12297006
